# LLM API key (BYOK),絕不進版控
secrets.json
# 本機環境變數。目前只有 PORT/DB_PATH/NODE_ENV,但這是最容易誤把 key 提交上去的地方
.env
.env.local
# 使用者的 UI 設定 (視窗位置、快捷鍵、LLM 端點)。預設值寫死在 electron.js,
# 檔案不存在時 readSettings() 回 {},所以不進版控也不影響全新 clone
settings.json
# 本機資料庫 (每台機器各自初始化,不進版控)
*.db
*.db-shm
*.db-wal
# DB 備份/損毀檔,只留本機
*.bak
*.bak-*
*.corrupt
# 第三方參考原始碼 (Lyricify),只是拿來讀,不進版控
Lyricify-*/
# 相依套件與建置產物
node_modules/
web-app/node_modules/
venv/
__pycache__/
dist-py/
dist-island/
build-py/
web-app/release/
DynamicIslandUI/bin/
DynamicIslandUI/obj/
# 執行期產物
app.pid
web-app/server_log.txt
# 個人筆記/截圖/PDF,不進版控
docs/
