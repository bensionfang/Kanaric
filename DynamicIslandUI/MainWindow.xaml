<Window x:Class="DynamicIslandUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="靈動島" Height="300" Width="800"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize"
        Topmost="True" ShowInTaskbar="False"
        WindowStartupLocation="Manual" Top="20"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        MouseMove="Window_MouseMove"
        MouseLeftButtonUp="Window_MouseLeftButtonUp">
    
    <Grid x:Name="MainContainer" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0">
        <Border x:Name="IslandBorder" Background="#CC000000" CornerRadius="0,0,40,40" Padding="20,15">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <!-- Album Art -->
            <Border Width="50" Height="50" CornerRadius="25" Margin="0,0,15,0" Background="#FF222222">
                <Border.Clip>
                    <EllipseGeometry RadiusX="25" RadiusY="25" Center="25,25"/>
                </Border.Clip>
                <Image x:Name="AlbumArt" Stretch="UniformToFill" />
            </Border>
            
            <Border x:Name="LyricsContainer" ClipToBounds="True" MaxWidth="480">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="SongText" Text="等待播放中..." Foreground="White" FontSize="14" FontWeight="Bold" />
                    <WrapPanel x:Name="LyricLine1" Orientation="Horizontal" Margin="0,4,0,0"/>
                    <WrapPanel x:Name="LyricLine2" Orientation="Horizontal" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Border>

        <!-- 左側外擴角 (Flare) -->
        <Path x:Name="LeftFlare" Fill="#CC000000" Opacity="1"
              HorizontalAlignment="Left" VerticalAlignment="Top"
              Margin="-19,0,0,0" Width="20" Height="20"
              Data="M 0,0 L 20,0 L 20,20 A 20,20 0 0 0 0,0 Z" />

        <!-- 右側外擴角 (Flare) -->
        <Path x:Name="RightFlare" Fill="#CC000000" Opacity="1"
              HorizontalAlignment="Right" VerticalAlignment="Top"
              Margin="0,0,-19,0" Width="20" Height="20"
              Data="M 0,0 L 20,0 A 20 20 0 0 0 0 20 Z" />
    </Grid>
</Window>
