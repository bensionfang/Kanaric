{
  "name": "kanaric",
  "version": "1.0.0",
  "description": "跨平台動態歌詞與聽歌分析系統",
  "main": "electron.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "app": "electron.cmd .",
    "build:py": "..\\venv\\Scripts\\python.exe -m PyInstaller --noconfirm --onedir --name pytools --collect-data pykakasi --collect-all unidic_lite --collect-data fugashi --distpath ..\\dist-py --workpath ..\\build-py --specpath ..\\build-py ..\\pytools.py",
    "dist": "npm run build:py && electron-builder",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "Resuaumis",
  "license": "GPL-3.0-or-later",
  "type": "commonjs",
  "dependencies": {
    "body-parser": "^2.2.2",
    "dotenv": "^17.4.2",
    "ejs": "^6.0.1",
    "electron-updater": "^6.8.9",
    "express": "^5.2.1",
    "opencc-js": "^1.4.1",
    "sqlite3": "^5.1.7",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "nodemon": "^3.1.14"
  },
  "build": {
    "appId": "com.resuaumis.kanaric",
    "productName": "Kanaric",
    "copyright": "Copyright © 2026 Resuaumis",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron.js",
      "server.js",
      "s2t.js",
      "browser-query.js",
      "title-lines.js",
      "translations.js",
      "island.js",
      "preload-island.js",
      "views/**",
      "public/**"
    ],
    "extraResources": [
      {
        "from": "../dist-py/pytools",
        "to": "pytools"
      },
      {
        "from": "../third_party",
        "to": "third_party"
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "bensionfang",
        "repo": "Kanaric"
      }
    ],
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": true,
      "deleteAppDataOnUninstall": false,
      "artifactName": "Kanaric-Setup-${version}.${ext}"
    }
  },
  "allowScripts": {
    "electron@33.4.11": true,
    "sqlite3@5.1.7": true
  }
}
