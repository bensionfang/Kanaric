<%- include('header') %>

<div class="page-header">
    <div>
        <h1>歌詞編輯器 (LRC Editor)</h1>
        <div class="subtitle">手動修正時間軸，儲存後立即同步到桌面版</div>
    </div>
</div>

<div class="stats-dashboard-grid">
    <div class="dashboard-card" style="flex: 1; display: flex; flex-direction: column;">
        <div class="card-header">
            <h3>選擇歌曲</h3>
        </div>
        <div style="display: flex; gap: 8px; margin-bottom: 10px;">
            <input type="text" id="title-search" placeholder="搜尋歌名..." style="flex: 1; background: var(--bg-main); color: var(--text-primary); border: 1px solid var(--panel-border); padding: 8px 12px; border-radius: 4px; font-family: inherit; font-size: 14px;">
            <input type="text" id="artist-search" placeholder="搜尋歌手..." style="flex: 1; background: var(--bg-main); color: var(--text-primary); border: 1px solid var(--panel-border); padding: 8px 12px; border-radius: 4px; font-family: inherit; font-size: 14px;">
        </div>
        <select id="song-select" size="10" style="width: 100%; flex: 1; background: var(--panel-bg); color: var(--text-primary); border: 1px solid var(--panel-border); padding: 10px; border-radius: 4px; font-family: monospace;">
            <option disabled>載入中...</option>
        </select>
    </div>

    <div class="dashboard-card" style="flex: 2;">
        <div class="card-header" style="display: flex; flex-direction: row !important; justify-content: space-between; align-items: center; gap: 15px; border-bottom: none; padding-bottom: 0;">
            <div id="editor-title" style="font-size: 20px; font-weight: bold; text-align: left; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; flex: 1;">請選擇歌曲...</div>
            <div style="display: flex; gap: 12px; flex-shrink: 0;">
                <button id="alias-btn" class="ctrl-btn" style="height: 38px; padding: 0 16px; font-size: 14px; width: auto; background: var(--panel-bg); color: var(--text-primary); border: 1px solid var(--panel-border); border-radius: 6px;" onclick="openAliasModal()" disabled><i class="fa-solid fa-users"></i> 設定歌手別名</button>
                <button id="advanced-btn" class="ctrl-btn" style="height: 38px; padding: 0 16px; font-size: 14px; width: auto; background: var(--panel-bg); color: var(--text-primary); border: 1px solid var(--panel-border); border-radius: 6px;" onclick="openEditorOptionsModal()" disabled><i class="fa-solid fa-magnifying-glass-plus"></i> 尋找更多歌詞</button>
                <button id="save-btn" class="ctrl-btn primary" style="height: 38px; padding: 0 20px; font-size: 14px; font-weight: 600; width: auto; border-radius: 6px;" disabled>儲存修改</button>
            </div>
        </div>
        <div id="lrc-editor-container" style="width: 100%; height: 500px; background: var(--bg-main); border: 1px solid var(--panel-border); padding: 15px; border-radius: 4px; overflow-y: auto;">
            <div style="color: var(--text-secondary); text-align: center; margin-top: 200px;">在左側選擇一首歌以開始編輯...</div>
        </div>
    </div>
</div>

<!-- Editor Advanced Options Modal -->
<div id="editor-options-modal" class="modal-overlay hidden">
    <div class="modal-content" style="padding: 20px; position: relative;">
        <button onclick="closeEditorOptionsModal()" style="position: absolute; top: 15px; right: 15px; background: transparent; border: none; color: var(--text-secondary); font-size: 18px; cursor: pointer; transition: color 0.3s;"><i class="fa-solid fa-xmark"></i></button>
        <h3><i class="fa-solid fa-magnifying-glass-plus"></i> 尋找更多歌詞</h3>
        <div class="modal-actions" style="display:flex; flex-direction:column; gap: 15px; margin-top: 15px;">
            <div style="padding-top: 5px;">
                <div style="display: flex; align-items: center; gap: 15px; margin-bottom: 10px;">
                    <h4 style="margin: 0; font-size: 14px;"><i class="fa-solid fa-list"></i> 取得備選歌詞</h4>
                    <button onclick="editorGetOptions()" class="nav-btn" style="padding: 4px 8px; font-size: 12px;"><i class="fa-solid fa-rotate-right"></i> 重新抓取備選歌詞</button>
                </div>
                
                <div style="display: flex; flex-direction: column; gap: 8px; margin-bottom: 10px;">
                    <div style="display: flex; gap: 8px;">
                        <input type="text" id="manual-search-title" placeholder="自訂搜尋歌名..." style="flex: 1; min-width: 0; background: var(--bg-main); color: var(--text-primary); border: 1px solid var(--panel-border); padding: 6px; border-radius: 4px; font-family: inherit; font-size: 13px;">
                        <input type="text" id="manual-search-artist" placeholder="自訂搜尋歌手..." style="flex: 1; min-width: 0; background: var(--bg-main); color: var(--text-primary); border: 1px solid var(--panel-border); padding: 6px; border-radius: 4px; font-family: inherit; font-size: 13px;">
                    </div>
                    <button onclick="editorManualSearch()" class="nav-btn" style="width: 100%; justify-content: center; padding: 8px; font-size: 13px;"><i class="fa-solid fa-search"></i> 以自訂關鍵字搜尋</button>
                </div>

                <div id="editor-options-list" style="margin-top: 10px; max-height: 150px; overflow-y: auto; display: flex; flex-direction: column; gap: 8px;"></div>
            </div>


            <div style="border-top: 1px solid var(--panel-border); padding-top: 15px;">
                <h4 style="margin-bottom: 10px; font-size: 14px;"><i class="fa-solid fa-paste"></i> 貼上自訂歌詞</h4>
                <textarea id="editor-custom-text" placeholder="貼上 LRC 格式或純文字歌詞..." style="width:100%; height:80px; margin-bottom:10px; background: var(--bg-main); border: 1px solid var(--panel-border); padding: 8px; color: var(--text-color); border-radius: 4px; resize: none;"></textarea>
                <button onclick="editorCustomLyrics()" class="nav-btn" style="width: 100%; justify-content: center;"><i class="fa-solid fa-check"></i> 載入自訂歌詞到編輯器</button>
            </div>
        </div>
    </div>
</div>

<!-- Alias Management Modal -->
<div id="alias-modal" class="modal-overlay hidden">
    <div class="modal-content" style="padding: 20px; position: relative; max-width: 500px; margin: 50px auto;">
        <button onclick="closeAliasModal()" style="position: absolute; top: 15px; right: 15px; background: transparent; border: none; color: var(--text-secondary); font-size: 18px; cursor: pointer; transition: color 0.3s;"><i class="fa-solid fa-xmark"></i></button>
        <h3><i class="fa-solid fa-users"></i> 歌手別名管理</h3>
        <p style="font-size: 13px; color: var(--text-secondary); margin-top: 5px; margin-bottom: 15px;">遇到被 Spotify 翻譯亂改名字的歌手？在這裡設定真名對應，系統會自動在背景使用真名幫你搜尋歌詞。</p>
        
        <div id="alias-list" style="max-height: 250px; overflow-y: auto; border: 1px solid var(--panel-border); border-radius: 6px; padding: 10px; margin-bottom: 15px; display: flex; flex-direction: column; gap: 8px;">
            <div style="text-align: center; color: var(--text-secondary); font-size: 13px;">載入中...</div>
        </div>
        
        <div style="display: flex; gap: 8px; align-items: center; border-top: 1px solid var(--panel-border); padding-top: 15px; flex-wrap: wrap;">
            <input type="text" id="new-alias" placeholder="Spotify 上的別名..." style="flex: 1; min-width: 0; background: var(--bg-main); color: var(--text-primary); border: 1px solid var(--panel-border); padding: 8px; border-radius: 4px; font-size: 13px;">
            <i class="fa-solid fa-arrow-right" style="color: var(--text-secondary);"></i>
            <input type="text" id="new-true-name" placeholder="正確的真名..." style="flex: 1; min-width: 0; background: var(--bg-main); color: var(--text-primary); border: 1px solid var(--panel-border); padding: 8px; border-radius: 4px; font-size: 13px;">
            <button onclick="addAlias()" class="ctrl-btn primary" style="width: auto; flex-shrink: 0; height: 34px; padding: 0 15px;"><i class="fa-solid fa-plus"></i> 新增</button>
        </div>
    </div>
</div>

<style>
    .lrc-row {
        display: flex;
        gap: 10px;
        margin-bottom: 8px;
        align-items: center;
        background: var(--panel-bg);
        padding: 6px 10px;
        border-radius: 6px;
        border: 1px solid var(--panel-border);
        transition: border-color 0.2s;
    }
    .lrc-row:focus-within {
        border-color: var(--accent-main);
    }
    .lrc-time {
        width: 90px;
        background: transparent;
        border: 1px solid var(--panel-border);
        color: var(--text-primary);
        padding: 4px 8px;
        border-radius: 4px;
        font-family: monospace;
        font-size: 14px;
        text-align: center;
    }
    .lrc-text {
        flex: 1;
        background: transparent;
        border: 1px solid transparent;
        color: var(--text-primary);
        padding: 4px 8px;
        font-size: 15px;
        border-radius: 4px;
        transition: background 0.2s;
    }
    .lrc-text:focus {
        background: var(--bg-main);
        border-color: var(--panel-border);
        outline: none;
    }
    .lrc-btn {
        background: transparent;
        border: none;
        color: var(--text-secondary);
        cursor: pointer;
        padding: 4px 8px;
        border-radius: 4px;
        transition: color 0.2s, background 0.2s;
    }
    .lrc-btn:hover {
        background: var(--bg-main);
    }
    .lrc-btn.add:hover { color: #1DB954; }
    .lrc-btn.del:hover { color: #ef4444; }
</style>

<script>
    const songSelect = document.getElementById('song-select');
    const editorTitle = document.getElementById('editor-title');
    const editorContainer = document.getElementById('lrc-editor-container');
    const saveBtn = document.getElementById('save-btn');
    const advancedBtn = document.getElementById('advanced-btn');
    const aliasBtn = document.getElementById('alias-btn');

    let currentArtist = "";
    let currentTitle = "";
    let lastFetchedSong = "";
    
    function openEditorOptionsModal() {
        const modal = document.getElementById('editor-options-modal');
        modal.classList.remove('hidden');
        modal.classList.add('show');
        
        const currentSongKey = currentTitle + "|" + currentArtist;
        if (lastFetchedSong !== currentSongKey) {
            editorGetOptions();
        }
    }

    function closeEditorOptionsModal() {
        const modal = document.getElementById('editor-options-modal');
        modal.classList.remove('show');
        setTimeout(() => modal.classList.add('hidden'), 300);
    }

    function applyLyricsToEditor(lyrics) {
        closeEditorOptionsModal();
        fetch('/api/lyrics/update', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ title: currentTitle, artist: currentArtist, lyrics: lyrics })
        })
        .then(res => res.json())
        .then(() => {
            loadRawLyrics();
        });
    }

    function editorCustomLyrics() {
        const text = document.getElementById('editor-custom-text').value.trim();
        if (text) applyLyricsToEditor(text);
    }

    function editorManualSearch() {
        const customTitle = document.getElementById('manual-search-title').value.trim();
        const customArtist = document.getElementById('manual-search-artist').value.trim();
        editorGetOptions(customTitle || undefined, customArtist || undefined);
    }

    async function editorGetOptions(customTitle, customArtist) {
        if (!currentTitle) return;
        
        const sTitle = customTitle !== undefined ? customTitle : currentTitle;
        const sArtist = customArtist !== undefined ? customArtist : currentArtist;
        
        lastFetchedSong = currentTitle + "|" + currentArtist;
        
        document.getElementById('manual-search-title').value = sTitle;
        document.getElementById('manual-search-artist').value = sArtist;

        const listEl = document.getElementById('editor-options-list');
        listEl.innerHTML = '<div style="color:var(--text-secondary); text-align:center;">搜尋中...</div>';
        
        try {
            const queryParams = new URLSearchParams({
                title: currentTitle,
                artist: currentArtist,
                searchTitle: sTitle,
                searchArtist: sArtist
            });
            const resp = await fetch(`/api/lyrics/options?${queryParams.toString()}`);
            const data = await resp.json();
            
            listEl.innerHTML = '';
            if (data.options && data.options.length > 0) {
                data.options.forEach(opt => {
                    const btn = document.createElement('button');
                    btn.className = 'nav-btn';
                    btn.style.flexDirection = 'column';
                    btn.style.alignItems = 'flex-start';
                    btn.style.padding = '8px 12px';
                    btn.innerHTML = `
                        <div style="display: flex; width: 100%; justify-content: space-between; align-items: center;">
                            <div style="flex: 1; min-width: 0; text-align: left;">
                                <div style="font-size: 13px; font-weight: 600; color: var(--text-primary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">${opt.title}</div>
                                <div style="font-size: 11px; color: var(--text-secondary); margin-top: 2px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">${opt.artist}${opt.album ? ' [' + opt.album + ']' : ''}</div>
                            </div>
                            <div style="display:flex; flex-direction:column; align-items:flex-end; flex-shrink: 0; margin-left: 10px;">
                                <div style="padding: 2px 6px; border-radius: 4px; font-size: 10px; font-weight: 600; ${opt.isSynced ? 'background: rgba(76, 175, 80, 0.15); color: #4caf50;' : 'background: rgba(158, 158, 158, 0.15); color: #9e9e9e;'}">
                                    ${opt.isSynced ? 'LRC' : 'TXT'}
                                </div>
                                <div style="font-size: 10px; color: var(--text-secondary); margin-top: 4px; opacity: 0.8;">${opt.provider || 'Unknown'}</div>
                            </div>
                        </div>
                    `;
                    btn.onclick = () => { applyLyricsToEditor(opt.lyrics); };
                    listEl.appendChild(btn);
                });
            } else {
                listEl.innerHTML = '<div style="color:var(--text-secondary); text-align:center;">找不到備選歌詞</div>';
            }
        } catch (e) {
            listEl.innerHTML = '<div style="color:var(--text-secondary); text-align:center;">搜尋失敗</div>';
        }
    }

    const titleSearch = document.getElementById('title-search');
    const artistSearch = document.getElementById('artist-search');
    let allSongs = [];

    function renderSongList(titleFilter = "", artistFilter = "") {
        songSelect.innerHTML = '';
        if (allSongs.length === 0) {
            songSelect.innerHTML = '<option disabled>資料庫中沒有快取的歌曲</option>';
            return;
        }
        
        const lowerTitle = titleFilter.toLowerCase();
        const lowerArtist = artistFilter.toLowerCase();
        const filteredSongs = allSongs.filter(song => 
            song.title.toLowerCase().includes(lowerTitle) && 
            song.artist.toLowerCase().includes(lowerArtist)
        );

        if (filteredSongs.length === 0) {
            songSelect.innerHTML = '<option disabled>找不到符合的歌曲</option>';
            return;
        }

        filteredSongs.forEach(song => {
            const opt = document.createElement('option');
            opt.value = JSON.stringify({ artist: song.artist, title: song.title });
            opt.text = `${song.title} - ${song.artist}`;
            songSelect.appendChild(opt);
        });
    }

    fetch('/api/songs')
        .then(res => res.json())
        .then(data => {
            allSongs = data;
            renderSongList();
        });

    function onSearchInput() {
        renderSongList(titleSearch.value, artistSearch.value);
    }

    titleSearch.addEventListener('input', onSearchInput);
    artistSearch.addEventListener('input', onSearchInput);

    function createRow(timeStr, textStr) {
        const row = document.createElement('div');
        row.className = 'lrc-row';
        
        const timeInput = document.createElement('input');
        timeInput.type = 'text';
        timeInput.className = 'lrc-time';
        timeInput.value = timeStr || '00:00.00';
        timeInput.placeholder = 'mm:ss.xx';
        
        const textInput = document.createElement('input');
        textInput.type = 'text';
        textInput.className = 'lrc-text';
        textInput.placeholder = '輸入歌詞...';
        
        const titleLabel = document.createElement('label');
        titleLabel.style.color = 'var(--text-secondary)';
        titleLabel.style.fontSize = '12px';
        titleLabel.style.cursor = 'pointer';
        titleLabel.style.display = 'flex';
        titleLabel.style.alignItems = 'center';
        titleLabel.style.gap = '4px';
        titleLabel.style.margin = '0 5px';
        titleLabel.title = '標記為標題行 (不顯示於靈動島且不標註假名)';
        
        const titleCheckbox = document.createElement('input');
        titleCheckbox.type = 'checkbox';
        titleCheckbox.className = 'lrc-title-cb';

        let actualText = textStr || '';
        if (actualText.startsWith('#TITLE#')) {
            titleCheckbox.checked = true;
            actualText = actualText.substring(7);
        }
        textInput.value = actualText;
        
        titleLabel.appendChild(titleCheckbox);
        titleLabel.appendChild(document.createTextNode('標題'));
        
        // Arrow key navigation
        textInput.addEventListener('keydown', (e) => {
            if (e.key === 'ArrowUp') {
                e.preventDefault();
                const prevRow = row.previousElementSibling;
                if (prevRow) prevRow.querySelector('.lrc-text').focus();
            } else if (e.key === 'ArrowDown') {
                e.preventDefault();
                const nextRow = row.nextElementSibling;
                if (nextRow) nextRow.querySelector('.lrc-text').focus();
            }
        });
        timeInput.addEventListener('keydown', (e) => {
            if (e.key === 'ArrowUp') {
                e.preventDefault();
                const prevRow = row.previousElementSibling;
                if (prevRow) prevRow.querySelector('.lrc-time').focus();
            } else if (e.key === 'ArrowDown') {
                e.preventDefault();
                const nextRow = row.nextElementSibling;
                if (nextRow) nextRow.querySelector('.lrc-time').focus();
            }
        });

        const addBtn = document.createElement('button');
        addBtn.className = 'lrc-btn add';
        addBtn.innerHTML = '<i class="fa-solid fa-plus"></i>';
        addBtn.title = "在此行下方插入新行";
        addBtn.onclick = () => {
            const newRow = createRow('', '');
            row.after(newRow);
            newRow.querySelector('.lrc-text').focus();
        };
        
        const delBtn = document.createElement('button');
        delBtn.className = 'lrc-btn del';
        delBtn.innerHTML = '<i class="fa-solid fa-trash"></i>';
        delBtn.title = "刪除此行";
        delBtn.onclick = () => row.remove();
        
        row.appendChild(timeInput);
        row.appendChild(textInput);
        row.appendChild(titleLabel);
        row.appendChild(addBtn);
        row.appendChild(delBtn);
        return row;
    }

    function parseAndRenderLRC(rawText) {
        editorContainer.innerHTML = '';
        const lines = rawText.split('\n');
        const regex = /^\[(\d{2}:\d{2}[\.:]\d{2,3})\](.*)/;
        
        let hasContent = false;
        lines.forEach(line => {
            if (!line.trim()) return;
            const match = line.match(regex);
            if (match) {
                editorContainer.appendChild(createRow(match[1], match[2]));
                hasContent = true;
            } else {
                if (line.startsWith('[source:')) return;
                // Keep metadata or malformed lines as generic rows without time
                if (line.startsWith('[')) {
                    editorContainer.appendChild(createRow(line, ''));
                    hasContent = true;
                } else if (!line.startsWith('#TITLE#')) {
                    editorContainer.appendChild(createRow('00:00.00', line));
                    hasContent = true;
                }
            }
        });
        
        if (!hasContent) {
            editorContainer.appendChild(createRow('00:00.00', '在此輸入歌詞...'));
        }
    }

    function loadRawLyrics() {
        editorTitle.innerText = `${currentTitle} - ${currentArtist}`;
        editorContainer.innerHTML = '<div style="color: var(--text-secondary); text-align: center; margin-top: 200px;">載入中...</div>';
        saveBtn.disabled = true;
        advancedBtn.disabled = true;
        aliasBtn.disabled = true;
        fetch(`/api/lyrics/raw?title=${encodeURIComponent(currentTitle)}&artist=${encodeURIComponent(currentArtist)}&plain=true`)
            .then(res => res.json())
            .then(data => {
                editorContainer.innerHTML = '';
                if (data.lyrics) {
                    parseAndRenderLRC(data.lyrics);
                    saveBtn.disabled = false;
                    advancedBtn.disabled = false;
                    aliasBtn.disabled = false;
                } else {
                    editorContainer.innerHTML = '<div style="color: var(--text-secondary); text-align: center; margin-top: 200px;">此歌曲沒有歌詞資料</div>';
                    saveBtn.disabled = true;
                    advancedBtn.disabled = false;
                    aliasBtn.disabled = false;
                }
            });
    }

    songSelect.addEventListener('change', (e) => {
        const selected = JSON.parse(e.target.value);
        currentArtist = selected.artist;
        currentTitle = selected.title;
        loadRawLyrics();
    });



    saveBtn.addEventListener('click', () => {
        saveBtn.innerText = "儲存中...";
        saveBtn.disabled = true;
        
        const rows = editorContainer.querySelectorAll('.lrc-row');
        let newLrcLines = [];
        
        rows.forEach(row => {
            const t = row.querySelector('.lrc-time').value.trim();
            const txt = row.querySelector('.lrc-text').value;
            const isTitle = row.querySelector('.lrc-title-cb') && row.querySelector('.lrc-title-cb').checked;
            const prefix = isTitle ? '#TITLE#' : '';
            // If it's a metadata tag like [ti:song], time field will have it
            if (t.startsWith('[') && t.endsWith(']')) {
                newLrcLines.push(t + prefix + txt);
            } else {
                newLrcLines.push(`[${t}]${prefix}${txt}`);
            }
        });
        
        const finalLrc = newLrcLines.join('\n');
        
        fetch('/api/lyrics/update', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ title: currentTitle, artist: currentArtist, lyrics: finalLrc })
        })
        .then(res => res.json())
        .then(data => {
            saveBtn.innerText = "已儲存！";
            setTimeout(() => {
                saveBtn.innerText = "儲存修改";
                saveBtn.disabled = false;
            }, 2000);
        });
    });

    function openAliasModal() {
        const modal = document.getElementById('alias-modal');
        modal.classList.remove('hidden');
        modal.classList.add('show');
        if (currentArtist) {
            document.getElementById('new-alias').value = currentArtist;
        }
        loadAliases();
    }

    function closeAliasModal() {
        const modal = document.getElementById('alias-modal');
        modal.classList.remove('show');
        setTimeout(() => modal.classList.add('hidden'), 300);
    }

    function loadAliases() {
        const list = document.getElementById('alias-list');
        list.innerHTML = '<div style="text-align: center; color: var(--text-secondary); font-size: 13px;">載入中...</div>';
        fetch('/api/aliases')
            .then(res => res.json())
            .then(data => {
                if (data.length === 0) {
                    list.innerHTML = '<div style="text-align: center; color: var(--text-secondary); font-size: 13px;">目前還沒有設定任何別名</div>';
                    return;
                }
                list.innerHTML = data.map(row => `
                    <div style="display: flex; justify-content: space-between; align-items: center; background: var(--bg-main); padding: 8px 12px; border-radius: 4px;">
                        <div style="display: flex; gap: 10px; align-items: center; font-size: 13px;">
                            <span style="color: var(--text-primary); font-weight: bold;">${row.alias}</span>
                            <i class="fa-solid fa-arrow-right" style="color: var(--text-secondary); font-size: 10px;"></i>
                            <span style="color: var(--text-primary);">${row.true_name}</span>
                        </div>
                        <button onclick="deleteAlias('${row.alias}')" style="background: transparent; border: none; color: #ff4757; cursor: pointer; font-size: 14px;"><i class="fa-solid fa-trash"></i></button>
                    </div>
                `).join('');
            });
    }

    function addAlias() {
        const alias = document.getElementById('new-alias').value.trim();
        const true_name = document.getElementById('new-true-name').value.trim();
        if (!alias || !true_name) return alert('請輸入別名與真名');
        
        fetch('/api/aliases', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ alias, true_name })
        })
        .then(res => res.json())
        .then(() => {
            document.getElementById('new-alias').value = '';
            document.getElementById('new-true-name').value = '';
            loadAliases();
        });
    }

    function deleteAlias(alias) {
        if (!confirm(`確定要刪除「${alias}」的別名設定嗎？`)) return;
        fetch(`/api/aliases/${encodeURIComponent(alias)}`, { method: 'DELETE' })
            .then(res => res.json())
            .then(() => loadAliases());
    }
</script>

