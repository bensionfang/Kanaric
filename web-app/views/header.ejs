<!DOCTYPE html>
<!-- 假名開關由 server 的 settings.json 決定,直接渲染進 class ——
     以前是前端讀 localStorage 補 class、checkbox 卻讀 server 值,兩邊會不同步:
     換瀏覽器 (localStorage 空) 時 server 設定等於失效,開關還要按兩下才生效。 -->
<html lang="zh-TW"<%- locals.settings && locals.settings.show_furigana === false ? ' class="hide-furigana"' : '' %>>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kanaric</title>
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Poppins:ital,wght@0,400;0,600;0,700;0,800;1,400;1,600;1,700;1,800&display=swap" rel="stylesheet">
    <!-- FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Style -->
    <link rel="stylesheet" href="/css/style.css?v=78">
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <!-- 各頁共用:吐司 + 備選歌詞 + 重新載入歌詞 -->
    <script src="/js/lyrics-tools.js?v=11" defer></script>
    <script>
        (function() {
            const fs = localStorage.getItem('fontsize');
            if (fs) {
                document.documentElement.style.setProperty('--lyrics-fs', fs + 'px');
            }
        })();
    </script>
</head>
<body>
    <!-- 無邊框視窗的拖曳區 -->
    <div class="win-drag"></div>
    <div class="app-container">
        <!-- Sidebar Navigation -->
        <aside class="sidebar collapsed" id="app-sidebar">
            <div class="brand">
                <button id="menu-dots-btn" class="menu-dots-btn" onclick="toggleSettingsMenu(event)" title="設定">
                    <i class="fa-solid fa-ellipsis"></i>
                </button>
                <!-- Settings Dropdown Menu -->
                <div id="settings-menu" class="settings-menu">
                    <div class="menu-row">
                        <span class="menu-label">顯示日文假名</span>
                        <label class="toggle-switch">
                            <input type="checkbox" id="setting-furigana" onchange="updateFuriganaSetting(this.checked)" checked>
                            <span class="slider round"></span>
                        </label>
                    </div>
                    <div class="menu-row">
                        <span class="menu-label">片假名標平假名</span>
                        <label class="toggle-switch">
                            <input type="checkbox" id="setting-katakana-ruby" onchange="updateKatakanaRuby(this.checked)">
                            <span class="slider round"></span>
                        </label>
                    </div>
                    <div class="menu-row">
                        <span class="menu-label">自動搜尋備選歌詞</span>
                        <label class="toggle-switch">
                            <input type="checkbox" id="setting-auto-lyrics-options" onchange="updateAutoLyricsOptions(this.checked)">
                            <span class="slider round"></span>
                        </label>
                    </div>
                    <div class="menu-row">
                        <span class="menu-label">歌詞文字大小</span>
                        <div class="menu-fontsize">
                            <input type="range" min="14" max="60" value="22" id="setting-fontsize" oninput="updateFontSize(this.value)">
                            <input type="number" id="fontsize-input" value="22" min="14" max="60" onchange="updateFontSize(this.value)" class="styled-input-number">
                        </div>
                    </div>
                    <div class="menu-row">
                        <span class="menu-label">歌詞對齊</span>
                        <div class="segmented-control" id="align-segmented">
                            <button class="segment-btn" data-align="left" onclick="changeTextAlign('left', this)">左</button>
                            <button class="segment-btn active" data-align="center" onclick="changeTextAlign('center', this)">中</button>
                            <button class="segment-btn" data-align="right" onclick="changeTextAlign('right', this)">右</button>
                        </div>
                    </div>
                    <div class="menu-row">
                        <span class="menu-label">靈動島歌詞行數</span>
                        <select id="setting-island-lines" class="menu-select" onchange="saveSettingsToServer('island_lines', parseInt(this.value))">
                            <option value="1">1 行</option>
                            <option value="2" selected>2 行</option>
                        </select>
                    </div>
                    <div class="menu-row">
                        <span class="menu-label">靈動島透明度</span>
                        <select id="setting-island-opacity" class="menu-select" onchange="saveSettingsToServer('island_opacity', parseFloat(this.value))">
                            <option value="1">不透明</option>
                            <option value="0.85">85%</option>
                            <option value="0.7">70%</option>
                            <option value="0.5">50%</option>
                        </select>
                    </div>
                    <div class="menu-row">
                        <span class="menu-label">鎖定靈動島位置</span>
                        <label class="toggle-switch">
                            <input type="checkbox" id="setting-island-locked" onchange="saveSettingsToServer('island_locked', this.checked)">
                            <span class="slider round"></span>
                        </label>
                    </div>
                    <div class="menu-row">
                        <span class="menu-label">優先搜尋來源</span>
                        <select id="setting-preferred-source" class="menu-select" onchange="localStorage.setItem('preferred_source', this.value); saveSettingsToServer('preferred_source', this.value)">
                            <option value="NetEase">NetEase (網易雲)</option>
                            <option value="Kugou">Kugou (酷狗)</option>
                            <option value="Lrclib">Lrclib</option>
                            <option value="Musixmatch">Musixmatch</option>
                            <option value="QQMusic">QQ 音樂</option>
                        </select>
                    </div>
                    <div class="menu-divider"></div>
                    <div class="menu-sub">
                    <button class="menu-row menu-action" id="source-toggle" onclick="toggleSourceSection(event)">
                        <span class="menu-label">音訊來源
                            <i class="fa-regular fa-circle-question llm-help-btn" title="什麼是音訊來源？" onclick="startSourceTour(event)"></i>
                        </span>
                        <i class="fa-solid fa-chevron-right hotkeys-chevron"></i>
                    </button>
                    <div class="menu-hotkeys" id="source-section"></div>
                    </div>
                    <div class="menu-sub">
                    <button class="menu-row menu-action" id="llm-toggle" onclick="toggleLlmSection(event)">
                        <span class="menu-label">AI 讀音校正
                            <i class="fa-regular fa-circle-question llm-help-btn" title="什麼是 AI 讀音校正？" onclick="startLlmTour(event)"></i>
                        </span>
                        <i class="fa-solid fa-chevron-right hotkeys-chevron"></i>
                    </button>
                    <div class="menu-hotkeys" id="llm-section">
                        <div class="hk-row">
                            <span class="hk-label">模式</span>
                            <select id="llm-mode" class="menu-select" onchange="saveSettingsToServer('llm_furigana', this.value)">
                                <option value="off" selected>手動</option>
                                <option value="fallback">自動 (無羅馬字來源時)</option>
                                <option value="always">總是</option>
                            </select>
                        </div>
                        <div class="hk-row">
                            <span class="hk-label">供應商</span>
                            <select id="llm-preset" class="menu-select" onchange="applyLlmPreset(this.value)">
                                <option value="">自訂</option>
                            </select>
                        </div>
                        <div class="hk-row">
                            <span class="hk-label">API Key</span>
                            <input type="password" id="llm-key" class="hk-input llm-input" placeholder="未設定" autocomplete="off" onchange="saveLlmApiKey(this)">
                        </div>
                        <div class="hk-row">
                            <span class="hk-label">Base URL</span>
                            <input type="text" id="llm-base-url" class="hk-input llm-input" onchange="saveSettingsToServer('llm_base_url', this.value.trim()); syncLlmPresetSelect()">
                        </div>
                        <div class="hk-row">
                            <span class="hk-label">Model</span>
                            <input type="text" id="llm-model" class="hk-input llm-input" list="llm-model-list" onchange="saveSettingsToServer('llm_model', this.value.trim())">
                            <datalist id="llm-model-list"></datalist>
                        </div>
                        <div class="hk-footer">
                            <span>啟用後會將歌名與歌詞送至你設定的 LLM 服務</span>
                        </div>
                    </div>
                    </div>
                    <div class="menu-sub">
                    <button class="menu-row menu-action" id="hotkeys-toggle" onclick="toggleHotkeysSection(event)">
                        <span class="menu-label">自訂快捷鍵</span>
                        <i class="fa-solid fa-chevron-right hotkeys-chevron"></i>
                    </button>
                    <div class="menu-hotkeys" id="hotkeys-section">
                        <div class="hk-row">
                            <span class="hk-label">歌詞快了</span>
                            <span class="hk-eye-slot"></span>
                            <input type="text" id="hk-advance" class="hk-input" readonly onclick="recordHotkey(this, 'hk-advance')">
                        </div>
                        <div class="hk-row">
                            <span class="hk-label">歌詞慢了</span>
                            <span class="hk-eye-slot"></span>
                            <input type="text" id="hk-delay" class="hk-input" readonly onclick="recordHotkey(this, 'hk-delay')">
                        </div>
                        <div class="hk-row">
                            <span class="hk-label">純文字上一句</span>
                            <span class="hk-eye-slot"></span>
                            <input type="text" id="hk-plain-prev" class="hk-input" readonly onclick="recordHotkey(this, 'hk-plain-prev')">
                        </div>
                        <div class="hk-row">
                            <span class="hk-label">純文字下一句</span>
                            <span class="hk-eye-slot"></span>
                            <input type="text" id="hk-plain-next" class="hk-input" readonly onclick="recordHotkey(this, 'hk-plain-next')">
                        </div>
                        <div class="hk-row">
                            <span class="hk-label">搜尋備選歌詞</span>
                            <button class="hk-eye" data-tool="lyrics-opt" onclick="toggleToolVisibility('lyrics-opt')" title="在工具列顯示/隱藏"><i class="fa-solid fa-eye"></i></button>
                            <input type="text" id="hk-lyrics-opt" class="hk-input" readonly onclick="recordHotkey(this, 'hk-lyrics-opt')">
                        </div>
                        <div class="hk-row">
                            <span class="hk-label">段落循環</span>
                            <button class="hk-eye" data-tool="ab-loop" onclick="toggleToolVisibility('ab-loop')" title="在工具列顯示/隱藏"><i class="fa-solid fa-eye"></i></button>
                            <input type="text" id="hk-ab-loop" class="hk-input" readonly onclick="recordHotkey(this, 'hk-ab-loop')">
                        </div>
                        <div class="hk-row">
                            <span class="hk-label">編輯假名模式</span>
                            <button class="hk-eye" data-tool="ruby-edit" onclick="toggleToolVisibility('ruby-edit')" title="在工具列顯示/隱藏"><i class="fa-solid fa-eye"></i></button>
                            <input type="text" id="hk-ruby-edit" class="hk-input" readonly onclick="recordHotkey(this, 'hk-ruby-edit')">
                        </div>
                        <div class="hk-row">
                            <span class="hk-label">AI 讀音校正</span>
                            <button class="hk-eye" data-tool="llm-wand" onclick="toggleToolVisibility('llm-wand')" title="在工具列顯示/隱藏"><i class="fa-solid fa-eye"></i></button>
                            <input type="text" id="hk-llm-wand" class="hk-input" readonly onclick="recordHotkey(this, 'hk-llm-wand')">
                        </div>
                        <div class="hk-row">
                            <span class="hk-label">重新載入歌詞</span>
                            <button class="hk-eye" data-tool="reload" onclick="toggleToolVisibility('reload')" title="在工具列顯示/隱藏"><i class="fa-solid fa-eye"></i></button>
                            <input type="text" id="hk-reload" class="hk-input" readonly onclick="recordHotkey(this, 'hk-reload')">
                        </div>
                        <div class="hk-row">
                            <span class="hk-label">桌面靈動島</span>
                            <button class="hk-eye" data-tool="island" onclick="toggleToolVisibility('island')" title="在工具列顯示/隱藏"><i class="fa-solid fa-eye"></i></button>
                            <input type="text" id="hk-island" class="hk-input" readonly onclick="recordHotkey(this, 'hk-island')">
                        </div>
                        <div class="hk-row">
                            <span class="hk-label">放大模式</span>
                            <button class="hk-eye" data-tool="fullscreen" onclick="toggleToolVisibility('fullscreen')" title="在工具列顯示/隱藏"><i class="fa-solid fa-eye"></i></button>
                            <input type="text" id="hk-fullscreen" class="hk-input" readonly onclick="recordHotkey(this, 'hk-fullscreen')">
                        </div>
                        <div class="hk-footer">
                            <span>點輸入框後按鍵綁定，ESC 取消</span>
                            <button class="hk-reset" onclick="resetHotkeys()">恢復預設</button>
                        </div>
                    </div>
                    </div>
                    <div class="menu-sub">
                    <button class="menu-row menu-action" id="data-toggle" onclick="toggleDataSection(event)">
                        <span class="menu-label">聆聽紀錄與資料</span>
                        <i class="fa-solid fa-chevron-right hotkeys-chevron"></i>
                    </button>
                    <div class="menu-hotkeys" id="data-section">
                        <div class="hk-row">
                            <span class="hk-label">記錄聆聽紀錄</span>
                            <label class="toggle-switch">
                                <input type="checkbox" id="setting-track-history" onchange="updateTrackHistory(this.checked)" checked>
                                <span class="slider round"></span>
                            </label>
                        </div>
                        <div class="hk-row">
                            <span class="hk-label hk-note">關閉後不再寫入紀錄，側欄的統計數據與排行榜也會一起隱藏。</span>
                        </div>
                        <div class="menu-divider"></div>
                        <div class="hk-row">
                            <span class="hk-label">歌詞快取 <b id="usage-lyrics">—</b></span>
                            <button class="hk-reset" onclick="clearDbData('lyrics')">清除</button>
                        </div>
                        <div class="hk-row">
                            <span class="hk-label">聆聽紀錄 <b id="usage-history">—</b></span>
                            <button class="hk-reset" onclick="clearDbData('history')">清除</button>
                        </div>
                        <div class="hk-row">
                            <span class="hk-label">手動修正 <b id="usage-manual">—</b></span>
                        </div>
                        <div class="hk-row">
                            <span class="hk-label hk-note">假名修正、時間軸校正等你自己改過的資料，清除功能不會動到。</span>
                        </div>
                        <div class="hk-footer">
                            <span>資料庫檔案 <b id="usage-file">—</b></span>
                        </div>
                    </div>
                    </div>
                    <button class="menu-row menu-action" onclick="startTour()">
                        <span class="menu-label">使用說明</span>
                        <i class="fa-solid fa-chevron-right"></i>
                    </button>
                </div>
            </div>
            
            <nav class="nav-menu">
                <a href="/" class="nav-item <%= activePage === 'home' ? 'active' : '' %>">
                    <i class="fa-solid fa-music"></i>
                    <span>歌詞</span>
                </a>
                <%# 關掉聆聽紀錄就沒東西可統計,兩項一起藏 (class 打在每個 a 上,不包 div ——
                    .nav-menu 是 flex column,多一層容器會吃掉 gap)。
                    路由本身留著:直接打網址仍看得到關掉之前的舊資料 %>
                <% const hideStats = settings.track_history === false ? ' hidden' : '' %>
                <a href="/stats" class="nav-item nav-stats-item<%= hideStats %> <%= activePage === 'stats' ? 'active' : '' %>">
                    <i class="fa-solid fa-chart-simple"></i>
                    <span>統計數據</span>
                </a>
                <a href="/leaderboard" class="nav-item nav-stats-item<%= hideStats %> <%= activePage === 'leaderboard' ? 'active' : '' %>">
                    <i class="fa-solid fa-trophy"></i>
                    <span>排行榜</span>
                </a>
                <a href="/editor" class="nav-item <%= activePage === 'editor' ? 'active' : '' %>">
                    <i class="fa-solid fa-pen-to-square"></i>
                    <span>歌詞編輯器</span>
                </a>
            </nav>
            
            <div class="sidebar-footer">
                <div class="version">Kanaric v<%= appVersion %></div>
                <a class="author-credit" href="https://github.com/<%= githubRepo %>" target="_blank" rel="noopener">by Resuaumis</a>
            </div>
        </aside>

        <!-- Main Body -->
        <main class="main-content <%= activePage === 'home' ? 'is-home-page' : '' %>">

            <div class="content-body">
