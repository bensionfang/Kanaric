<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Floating Lyrics - Web Premium</title>
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <!-- FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Style -->
    <link rel="stylesheet" href="/css/style.css">
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>
    <div class="app-container">
        <!-- Sidebar Navigation -->
        <aside class="sidebar">
            <div class="brand">
                <div class="brand-icon">
                    <i class="fa-solid fa-compact-disc fa-spin-slow"></i>
                </div>
                <h2>Floating Lyrics</h2>
            </div>
            
            <nav class="nav-menu">
                <a href="/" class="nav-item <%= activePage === 'home' ? 'active' : '' %>">
                    <i class="fa-solid fa-music"></i>
                    <span>音樂播放器</span>
                </a>
                <a href="/stats" class="nav-item <%= activePage === 'stats' ? 'active' : '' %>">
                    <i class="fa-solid fa-chart-simple"></i>
                    <span>統計數據</span>
                </a>
            </nav>
            
            <div class="sidebar-footer">
                <div class="version">v2.0.0 Web Premium</div>
            </div>
        </aside>

        <!-- Main Body -->
        <main class="main-content">
            <header class="top-bar">
                <div class="time-widget">
                    <i class="fa-regular fa-clock"></i>
                    <span id="live-clock">--:--:--</span>
                </div>
                <div class="user-profile">
                    <div class="avatar"><i class="fa-solid fa-graduation-cap"></i></div>
                    <span>期末演示模式</span>
                </div>
            </header>

            <div class="content-body">
