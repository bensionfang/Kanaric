<!DOCTYPE html>
<!-- 假名開關由 server 直接渲染,做法與 header.ejs 相同 (載入就是對的,不會閃一下) -->
<html lang="zh-TW"<%- locals.settings && locals.settings.show_furigana === false ? ' class="hide-furigana"' : '' %>>
<head>
<meta charset="UTF-8">
<title>Kanaric Island</title>
<link rel="stylesheet" href="/css/island.css?v=12">
</head>
<body>
<div id="island" class="docked">
  <div id="art"></div>
  <div id="lines">
    <div id="song">等待播放…</div>
    <div id="l1" class="hidden"></div>
    <div id="l2" class="hidden"></div>
  </div>
  <!-- 右端的播放狀態:跟左端封面等寬,版面才左右平衡 (播放中跳動、暫停時定住) -->
  <div id="state"><i></i><i></i><i></i></div>
</div>
<div id="measure"><div id="m1"></div><div id="m2"></div></div>

<script>
const el = {
  island: document.getElementById('island'), art: document.getElementById('art'),
  song: document.getElementById('song'), l1: document.getElementById('l1'), l2: document.getElementById('l2'),
  state: document.getElementById('state'),
  m1: document.getElementById('m1'), m2: document.getElementById('m2')
};

// 量這兩行要多大,請主進程把視窗縮放到剛好包住 —— 島才不會是個固定的大黑框。
// 寬度量在 #measure (絕對定位) 上,視窗此刻多窄都不影響量到的自然寬度;
// 高度直接量 #island 自己 (height:auto),所以 ruby 有沒有顯示、幾行、字多大都自動貼合。
function fitSize(line1, line2, firstEl) {
  // 字重也要跟著複製:主行是 500,量在預設 400 上會少算幾 px,長句就會被切掉尾巴
  const copyFont = (node, from) => {
    const cs = getComputedStyle(from);
    node.style.fontSize = cs.fontSize;
    node.style.fontWeight = cs.fontWeight;
  };
  el.m1.innerHTML = line1 || '';
  copyFont(el.m1, firstEl || el.l1);
  el.m2.innerHTML = line2 || '';
  copyFont(el.m2, el.l2);
  const textW = Math.max(el.m1.offsetWidth, el.m2.offsetWidth);
  const cs = getComputedStyle(el.island);
  const gap = parseFloat(cs.gap || 12);
  const chrome = el.art.offsetWidth + el.state.offsetWidth + gap * 2
    + parseFloat(cs.paddingLeft) + parseFloat(cs.paddingRight);
  bridge.resize({
    width: Math.ceil(textW + chrome) + 2,   // +2 避免尾字被四捨五入切掉
    height: Math.ceil(el.island.offsetHeight)
  });
}

// preload 只有在 Electron 島視窗裡才存在;用瀏覽器直接開 /island 除錯時降級成空實作
const bridge = window.islandBridge || {
  dragStart() {}, dragEnd() {}, toggleDock() {}, resize() {}, onDocked() {}
};

// ── 拖曳:自己判斷有沒有真的移動,幾乎沒動就當成單擊 (切換吸附) ──
let downAt = null;
document.addEventListener('mousedown', (e) => {
  downAt = { x: e.screenX, y: e.screenY };
  bridge.dragStart();
});
document.addEventListener('mouseup', (e) => {
  if (!downAt) return;
  const moved = Math.abs(e.screenX - downAt.x) > 2 || Math.abs(e.screenY - downAt.y) > 2;
  downAt = null;
  bridge.dragEnd();
  if (!moved) bridge.toggleDock();
});
bridge.onDocked(d => el.island.classList.toggle('docked', d));

// ── 狀態 ──
let lyrics = [], songKey = '', pos = 0, playing = false, lastSync = 0, offset = 0;
let islandLines = 2, lastLine1 = null, idleTimer = null, wasPlaying = null, wasHasSession = null;
// 第二行顯示什麼:'next' 下一句歌詞 (預設) / 'translation' 本句翻譯
let islandLine2 = 'next';
// 時間戳 -> 譯文。譯文行不進 lyrics[],否則會被當成獨立一句輪播過去
let translations = {};

function applySettings(s) {
  if (!s) return;
  document.documentElement.classList.toggle('hide-furigana', s.show_furigana === false);
  islandLines = Number(s.island_lines) === 1 ? 1 : 2;
  islandLine2 = s.island_line2 === 'translation' ? 'translation' : 'next';
  const scale = Math.max(0.6, Math.min(1.6, (Number(s.font_size) || 32) / 32));
  // 島的字比網頁小一截:font_size 32 → 16px。放大就會把整條撐胖,失去「一條細帶」的感覺
  document.documentElement.style.setProperty('--island-fs', Math.round(16 * scale) + 'px');
  const op = s.island_opacity === undefined ? 1 : Number(s.island_opacity);
  document.documentElement.style.setProperty('--island-opacity', isNaN(op) ? 1 : op);
  // 行數只在「換行時」才會被套用 (frame() 判到 line1 沒變就提早 return),
  // 所以這裡要自己收掉第二行,並清掉 lastLine1 讓下一幀重畫 (1 → 2 行時把內容補回來)
  if (islandLines === 1) el.l2.classList.add('hidden');
  lastLine1 = null;
  // 有歌詞的話下一幀重畫時就會回報尺寸;停在歌名畫面 (前奏/剛換歌) 沒有重畫,自己報一次
  if (!el.song.classList.contains('hidden')) fitSize(el.song.textContent, '', el.song);
}

// ── WebSocket:歌曲狀態、歌詞、設定、時間軸偏移全部靠推播 ──
function connect() {
  const ws = new WebSocket(`ws://${location.host}`);
  ws.onmessage = (ev) => {
    let msg; try { msg = JSON.parse(ev.data); } catch (e) { return; }
    if (msg.type === 'init' || msg.type === 'media_state') {
      if (msg.settings) applySettings(msg.settings);
      onMediaState(msg.state || {});
    } else if (msg.type === 'lyrics_updated') {
      if (msg.artist + '|||' + msg.title === songKey) setLyrics(msg.lyrics || '');
    } else if (msg.type === 'settings_updated') {
      applySettings(msg.settings);
    } else if (msg.type === 'sync_offset_updated') {
      offset = msg.offset || 0;
    }
  };
  ws.onclose = () => { el.song.textContent = '伺服器斷線'; setTimeout(connect, 3000); };
  ws.onerror = () => ws.close();
}
connect();

async function onMediaState(m) {
  playing = !!m.is_playing;
  pos = m.position || 0;
  lastSync = performance.now();
  // 暫停 3 秒後淡出,恢復播放立刻淡回來。
  // **只在狀態真的改變時才動計時器**:media_monitor 每 0.1 秒就回報一次,
  // 每次都 clearTimeout 的話那 3 秒永遠數不完,島就一直不會淡出。
  //
  // 「完全沒有播放來源」與「有歌但暫停」要分開:前者代表使用者剛把島打開、還沒開始放歌,
  // 這時候淡出的話畫面上什麼都沒有,看起來就像島根本沒開。那個情況要保持可見顯示「等待播放…」。
  const hasSession = !!m.title;
  if (playing !== wasPlaying || hasSession !== wasHasSession) {
    wasPlaying = playing;
    wasHasSession = hasSession;
    el.island.classList.toggle('playing', playing);   // 右端等化器動不動看這個
    clearTimeout(idleTimer);
    if (playing || !hasSession) el.island.classList.remove('idle');
    else idleTimer = setTimeout(() => el.island.classList.add('idle'), 3000);
  }

  // 播放來源整個消失 (音樂 app 關掉了):要退回「等待播放…」,不然島會一直掛著上一首的歌詞。
  // 這一段以前不存在也沒差,因為沒 session 就淡出看不見了;現在不淡出,就得自己收乾淨。
  if (!m.title) {
    if (songKey !== '') {
      songKey = ''; lyrics = []; lastLine1 = null;
      el.art.style.backgroundImage = '';
      el.song.textContent = '等待播放…';
      el.song.classList.remove('hidden');
      el.l1.classList.add('hidden');
      el.l2.classList.add('hidden');
      fitSize(el.song.textContent, '', el.song);
    }
    return;
  }

  // resolving = 歌名還沒定案 (iTunes 日文原名還原中),等定案再抓,否則會抓兩次
  const key = (m.artist || '') + '|||' + (m.title || '');
  if (m.resolving || key === songKey) return;
  songKey = key;
  lyrics = []; lastLine1 = null;
  el.art.style.backgroundImage = m.thumbnail ? `url(data:image/png;base64,${m.thumbnail})` : '';
  showSongName(m.title, m.artist);

  const q = new URLSearchParams({ title: m.title, artist: m.artist });
  try {
    const d = await (await fetch('/api/lyrics/fetch?' + q)).json();
    if (songKey === key) setLyrics(d.lyrics || '');
  } catch (e) {}
  try {
    const o = await (await fetch('/api/lyrics/offset?' + q)).json();
    if (songKey === key) offset = o.offset || 0;
  } catch (e) {}
}

function showSongName(title, artist) {
  el.song.textContent = artist ? `${title} - ${artist}` : title;
  el.song.classList.remove('hidden');
  el.l1.classList.add('hidden');
  el.l2.classList.add('hidden');
  fitSize(el.song.textContent, '', el.song);
}

function setLyrics(text) {
  lyrics = parseLrc(text);
  lastLine1 = null;
}

function parseLrc(text) {
  const out = [];
  translations = {};
  for (const line of text.split('\n')) {
    const m = line.match(/^((?:\[\d+:\d+(?:\.\d+)?\])+)(.*)$/);
    if (!m) continue;
    const html = m[2].trim();
    if (html.startsWith('#TITLE#')) continue;   // 製作人員列不進島
    for (const tag of m[1].match(/\[\d+:\d+(?:\.\d+)?\]/g) || []) {
      const [mm, ss] = tag.slice(1, -1).split(':');
      const t = parseInt(mm) * 60 + parseFloat(ss);
      // 譯文與原句共用時間戳,收進對照表而不是當成獨立一句
      if (html.startsWith('#TRANS#')) translations[t] = html.substring(7);
      else out.push({ t, html });
    }
  }
  return out.sort((a, b) => a.t - b.t);
}

// 空行 (間奏) 落在活躍位置時,先看下一句,沒有再往回找最後一句有字的
function pickLines(i) {
  let line1 = lyrics[i].html;
  let line2 = '';
  // 第二行選「本句翻譯」時優先用譯文;這首歌沒有譯文就照舊退回「下一句歌詞」,
  // 不然切了設定卻整片空白,看起來像壞掉
  if (islandLine2 === 'translation' && line1) {
    const t = translations[lyrics[i].t];
    if (t) return [line1, t];
  }
  if (!line1) {
    if (i + 1 < lyrics.length) {
      line1 = lyrics[i + 1].html;
      if (i + 2 < lyrics.length && lyrics[i + 2].html) line2 = lyrics[i + 2].html;
    } else {
      for (let k = i - 1; k >= 0; k--) if (lyrics[k].html) { line1 = lyrics[k].html; break; }
    }
  } else if (i + 1 < lyrics.length) {
    if (lyrics[i + 1].html) line2 = lyrics[i + 1].html;
    else if (i + 2 < lyrics.length && lyrics[i + 2].html) line2 = lyrics[i + 2].html;
  }
  return [line1, line2];
}

function paint(node, html) {
  node.innerHTML = html;
  node.classList.remove('hidden', 'lyric-anim');
  void node.offsetWidth;          // 強制 reflow,動畫才會重播
  node.classList.add('lyric-anim');
}

// 島沒有 DevTools 可開 (無邊框視窗),留一個查狀態的入口:瀏覽器開 /island 或主進程都能問
window.__islandDebug = () => ({ songKey, lines: lyrics.length, pos, playing, offset, islandLines, lastLine1 });

// 進度用 rAF 內插,跟網頁同一套做法,免得一秒才跳一次
function frame() {
  requestAnimationFrame(frame);
  if (!lyrics.length) return;
  // 早 0.5 秒切換:抵銷淡入動畫與傳輸延遲,看起來才「跟手」(沿用舊島的補償值)
  const now = pos + (playing ? (performance.now() - lastSync) / 1000 : 0) - offset + 0.5;
  if (now < lyrics[0].t) {                    // 前奏:顯示歌名
    if (lastLine1 !== 'INTRO') { lastLine1 = 'INTRO'; el.song.classList.remove('hidden');
      el.l1.classList.add('hidden'); el.l2.classList.add('hidden');
      fitSize(el.song.textContent, '', el.song); }
    return;
  }
  let i = -1;
  for (let k = 0; k < lyrics.length; k++) if (lyrics[k].t <= now) i = k; else break;
  if (i < 0) return;
  const [line1, line2] = pickLines(i);
  if (line1 === lastLine1) return;
  lastLine1 = line1;
  el.song.classList.add('hidden');
  paint(el.l1, line1);
  const showLine2 = !!line2 && islandLines === 2;
  if (showLine2) paint(el.l2, line2);
  else el.l2.classList.add('hidden');
  fitSize(line1, showLine2 ? line2 : '');
}
requestAnimationFrame(frame);
</script>
</body>
</html>
