<%- include('header') %>

<div class="page-header animate-fade-in">
    <div>
        <h1>排行榜</h1>
    </div>
    
    <button class="refresh-btn" onclick="loadLeaderboard()">
        <i class="fa-solid fa-arrows-rotate" id="refresh-icon"></i> 立即更新
    </button>
</div>

<!-- ================= 篩選工具列 ================= -->
<div class="animate-fade-in" style="display: flex; gap: 20px; margin-bottom: 30px; flex-wrap: wrap;">
    <!-- 類別篩選 -->
    <div style="display: flex; flex-direction: column; gap: 8px;">
        <span style="font-size: 11px; color: var(--text-dim); text-transform: uppercase; letter-spacing: 1px;">排行類別</span>
        <div class="mode-tabs" id="type-tabs">
            <button class="mode-tab active" data-type="tracks" onclick="changeType('tracks')">
                <i class="fa-solid fa-music"></i> 熱門曲目
            </button>
            <button class="mode-tab" data-type="artists" onclick="changeType('artists')">
                <i class="fa-solid fa-user-astronaut"></i> 熱門藝人
            </button>
            <button class="mode-tab" data-type="albums" onclick="changeType('albums')">
                <i class="fa-solid fa-record-vinyl"></i> 熱門專輯
            </button>
        </div>
    </div>

    <!-- 時間範圍篩選 -->
    <div style="display: flex; flex-direction: column; gap: 8px;">
        <span style="font-size: 11px; color: var(--text-dim); text-transform: uppercase; letter-spacing: 1px;">統計時間</span>
        <div class="mode-tabs" id="range-tabs">
            <button class="mode-tab active" data-range="all" onclick="changeRange('all')">所有時間</button>
            <button class="mode-tab" data-range="6m" onclick="changeRange('6m')">近 6 個月</button>
            <button class="mode-tab" data-range="1m" onclick="changeRange('1m')">近 1 個月</button>
        </div>
    </div>
</div>

<!-- ================= 排行榜資料卡 ================= -->
<div class="dashboard-card glass-panel animate-fade-in" style="margin-bottom: 40px; border: 1px solid var(--panel-border); border-radius: 4px; padding: 30px;">
    <div class="card-header" style="border-bottom: 1px solid var(--panel-border); padding-bottom: 15px; margin-bottom: 20px;">
        <h3 id="board-title"><i class="fa-solid fa-trophy"></i> 熱門曲目排行榜</h3>
        <span class="header-desc" id="board-desc">依播放次數排序的熱門金曲</span>
    </div>
    
    <div class="table-container">
        <table class="premium-table">
            <thead>
                <tr id="table-header-row">
                    <th style="width: 80px; text-align: center;">排名</th>
                    <th>曲目資訊</th>
                    <th style="width: 150px; text-align: right;">播放次數</th>
                    <th style="width: 180px; text-align: right;">累計時間</th>
                </tr>
            </thead>
            <tbody id="leaderboard-table-body">
                <tr>
                    <td colspan="4" class="table-empty">
                        <i class="fa-solid fa-spinner fa-spin"></i> 載入排行榜數據中...
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<script>
    let currentType = 'tracks';
    let currentRange = 'all';

    document.addEventListener('DOMContentLoaded', () => {
        loadLeaderboard();
        
        // Auto refresh every 10 seconds to avoid lagging when in active use
        setInterval(() => {
            loadLeaderboard(false);
        }, 10000);
    });

    function changeType(type) {
        currentType = type;
        
        // Toggle active tab class
        const tabs = document.querySelectorAll('#type-tabs .mode-tab');
        tabs.forEach(tab => {
            if (tab.getAttribute('data-type') === type) {
                tab.classList.add('active');
            } else {
                tab.classList.remove('active');
            }
        });
        
        // Update headers dynamically
        const boardTitle = document.getElementById('board-title');
        const boardDesc = document.getElementById('board-desc');
        const headerRow = document.getElementById('table-header-row');
        
        if (type === 'tracks') {
            boardTitle.innerHTML = '<i class="fa-solid fa-music"></i> 熱門曲目排行榜';
            boardDesc.textContent = '依播放次數排序的熱門金曲';
            headerRow.innerHTML = `
                <th style="width: 80px; text-align: center;">排名</th>
                <th>曲目資訊</th>
                <th style="width: 150px; text-align: right;">播放次數</th>
                <th style="width: 180px; text-align: right;">累計時間</th>
            `;
        } else if (type === 'artists') {
            boardTitle.innerHTML = '<i class="fa-solid fa-user-astronaut"></i> 熱門藝人排行榜';
            boardDesc.textContent = '依總播放次數排序的最佳歌手與樂團';
            headerRow.innerHTML = `
                <th style="width: 80px; text-align: center;">排名</th>
                <th>藝人 / 歌手</th>
                <th style="width: 150px; text-align: right;">播放次數</th>
                <th style="width: 180px; text-align: right;">累計時間</th>
            `;
        } else if (type === 'albums') {
            boardTitle.innerHTML = '<i class="fa-solid fa-record-vinyl"></i> 熱門專輯排行榜';
            boardDesc.textContent = '依總播放次數排序的音樂專輯';
            headerRow.innerHTML = `
                <th style="width: 80px; text-align: center;">排名</th>
                <th>專輯資訊</th>
                <th style="width: 150px; text-align: right;">播放次數</th>
                <th style="width: 180px; text-align: right;">累計時間</th>
            `;
        }
        
        loadLeaderboard();
    }

    function changeRange(range) {
        currentRange = range;
        
        // Toggle active tab class
        const tabs = document.querySelectorAll('#range-tabs .mode-tab');
        tabs.forEach(tab => {
            if (tab.getAttribute('data-range') === range) {
                tab.classList.add('active');
            } else {
                tab.classList.remove('active');
            }
        });
        
        loadLeaderboard();
    }

    async function loadLeaderboard(showSpinner = true) {
        const refreshIcon = document.getElementById('refresh-icon');
        const tableBody = document.getElementById('leaderboard-table-body');
        
        if (showSpinner) {
            if (refreshIcon) refreshIcon.classList.add('fa-spin');
            tableBody.innerHTML = `
                <tr>
                    <td colspan="4" class="table-empty">
                        <i class="fa-solid fa-spinner fa-spin"></i> 載入排行榜數據中...
                    </td>
                </tr>
            `;
        }

        try {
            const resp = await fetch(`/api/leaderboard?type=${currentType}&range=${currentRange}`);
            if (resp.ok) {
                const data = await resp.json();
                
                if (data.length === 0) {
                    tableBody.innerHTML = `
                        <tr>
                            <td colspan="4" class="table-empty">
                                <i class="fa-solid fa-circle-question"></i> 在此統計區間內尚無播放紀錄！
                            </td>
                        </tr>
                    `;
                    return;
                }
                
                tableBody.innerHTML = data.map((item, index) => {
                    let rankBadge = '';
                    if (index === 0) rankBadge = '<span class="rank-badge rank-1"><i class="fa-solid fa-trophy"></i> 1</span>';
                    else if (index === 1) rankBadge = '<span class="rank-badge rank-2">2</span>';
                    else if (index === 2) rankBadge = '<span class="rank-badge rank-3">3</span>';
                    else rankBadge = `<span class="rank-num">${index + 1}</span>`;
                    
                    const totalMin = Math.round(item.duration / 60);
                    
                    let infoCell = '';
                    if (currentType === 'tracks') {
                        infoCell = `
                            <div class="song-info-cell">
                                <div class="song-meta">
                                    <span class="song-title">${escapeHtml(item.title)}</span>
                                    <span class="song-artist">${escapeHtml(item.artist)}</span>
                                </div>
                            </div>
                        `;
                    } else if (currentType === 'artists') {
                        infoCell = `
                            <div class="song-info-cell">
                                <div class="song-meta">
                                    <span class="song-title" style="font-size: 14px; font-weight: 500;">${escapeHtml(item.artist)}</span>
                                </div>
                            </div>
                        `;
                    } else if (currentType === 'albums') {
                        infoCell = `
                            <div class="song-info-cell">
                                <div class="song-meta">
                                    <span class="song-title">${escapeHtml(item.album)}</span>
                                    <span class="song-artist">${escapeHtml(item.artist)}</span>
                                </div>
                            </div>
                        `;
                    }
                    
                    return `
                        <tr>
                            <td style="text-align: center;">${rankBadge}</td>
                            <td>${infoCell}</td>
                            <td style="text-align: right; font-weight: 600; color: var(--text-primary);">
                                ${item.count} 次
                            </td>
                            <td style="text-align: right; color: var(--text-secondary);">
                                ${totalMin} 分鐘
                            </td>
                        </tr>
                    `;
                }).join('');
            }
        } catch (err) {
            console.error('Error loading leaderboard:', err);
            tableBody.innerHTML = `
                <tr>
                    <td colspan="4" class="table-empty" style="color: #ef4444;">
                        <i class="fa-solid fa-triangle-exclamation"></i> 載入數據失敗，請稍後再試。
                    </td>
                </tr>
            `;
        } finally {
            if (refreshIcon) {
                setTimeout(() => {
                    refreshIcon.classList.remove('fa-spin');
                }, 600);
            }
        }
    }

    function escapeHtml(text) {
        if (!text) return '';
        const map = {
            '&': '&amp;',
            '<': '&lt;',
            '>': '&gt;',
            '"': '&quot;',
            "'": '&#039;'
        };
        return text.replace(/[&<>"']/g, function(m) { return map[m]; });
    }
</script>

<%- include('footer') %>
