<!-- 備選歌詞:從播放列的按鈕往上展開的浮層 (錨點是 .lyrics-opt-wrap),不是全螢幕 modal -->
<div id="lyrics-options-modal" class="lyrics-opt-panel">
    <div class="lyrics-opt-head">
        <span><i class="fa-solid fa-list"></i> 備選歌詞</span>
        <button class="lyrics-opt-refresh" onclick="searchLyricsOptions(true)" title="重新抓取備選歌詞">
            <i class="fa-solid fa-rotate-right"></i>
        </button>
    </div>
    <div class="lyrics-opt-search">
        <input type="text" id="manual-title" placeholder="自訂歌名…">
        <input type="text" id="manual-artist" placeholder="自訂歌手…">
    </div>
    <button class="lyrics-opt-search-btn" onclick="manualSearchLyrics()">
        <i class="fa-solid fa-search"></i> 以自訂關鍵字搜尋
    </button>
    <div id="lyrics-options-list"></div>
</div>
