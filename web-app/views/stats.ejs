<%- include('header') %>

<div class="page-header animate-fade-in">
    <div>
        <h1>統計數據</h1>
    </div>
</div>

<!-- ================= 數據概覽卡片 ================= -->
<div class="stats-overview-grid animate-fade-in">
    <!-- 卡片 1: 播放總時長 -->
    <div class="stats-card glass-panel">
        <div class="card-icon"><i class="fa-solid fa-clock"></i></div>
        <div class="card-info">
            <span class="card-label">播放總時長</span>
            <h2 class="card-value" id="stat-total-time">0 分鐘</h2>
            <span class="card-trend"><i class="fa-solid fa-hourglass-half"></i> 累計聆聽時間</span>
        </div>
    </div>
    <!-- 卡片 2: 播放次數 -->
    <div class="stats-card glass-panel">
        <div class="card-icon"><i class="fa-solid fa-play"></i></div>
        <div class="card-info">
            <span class="card-label">播放次數</span>
            <h2 class="card-value" id="stat-total-plays">0</h2>
            <span class="card-trend"><i class="fa-solid fa-arrow-trend-up"></i> 播放事件累計</span>
        </div>
    </div>
    <!-- 卡片 3: 聽歌活躍天數 -->
    <div class="stats-card glass-panel">
        <div class="card-icon"><i class="fa-solid fa-calendar-check"></i></div>
        <div class="card-info">
            <span class="card-label">聽歌活躍天數</span>
            <h2 class="card-value" id="stat-active-days">0 天</h2>
            <span class="card-trend"><i class="fa-solid fa-sun"></i> 使用 Kanaric 天數</span>
        </div>
    </div>
    <!-- 卡片 4: 最常聽歌時段 -->
    <div class="stats-card glass-panel">
        <div class="card-icon"><i class="fa-solid fa-cloud-moon"></i></div>
        <div class="card-info">
            <span class="card-label">最常聽歌時段</span>
            <h2 class="card-value" id="stat-fav-period">-</h2>
            <span class="card-trend"><i class="fa-solid fa-star"></i> 你的音樂生理時鐘</span>
        </div>
    </div>
    <!-- 卡片 5: 不同的曲目 -->
    <div class="stats-card glass-panel">
        <div class="card-icon"><i class="fa-solid fa-music"></i></div>
        <div class="card-info">
            <span class="card-label">不同的曲目</span>
            <h2 class="card-value" id="stat-total-songs">0</h2>
            <span class="card-trend"><i class="fa-solid fa-compact-disc"></i> 獨特歌曲庫</span>
        </div>
    </div>
    <!-- 卡片 6: 不同的藝人 -->
    <div class="stats-card glass-panel">
        <div class="card-icon"><i class="fa-solid fa-user-astronaut"></i></div>
        <div class="card-info">
            <span class="card-label">不同的藝人</span>
            <h2 class="card-value" id="stat-total-artists">0</h2>
            <span class="card-trend"><i class="fa-solid fa-users"></i> 探索藝人廣度</span>
        </div>
    </div>
    <!-- 卡片 7: 單曲最高循環次數 -->
    <div class="stats-card glass-panel">
        <div class="card-icon"><i class="fa-solid fa-repeat"></i></div>
        <div class="card-info">
            <span class="card-label">單曲最高循環次數</span>
            <h2 class="card-value" id="stat-max-loop">0 次</h2>
            <span class="card-trend"><i class="fa-solid fa-fire"></i> 最洗腦神曲播放量</span>
        </div>
    </div>
    <!-- 卡片 8: 每日平均播放分鐘數 -->
    <div class="stats-card glass-panel">
        <div class="card-icon"><i class="fa-solid fa-chart-line"></i></div>
        <div class="card-info">
            <span class="card-label">每日平均播放分鐘數</span>
            <h2 class="card-value" id="stat-daily-avg-minutes">0 分</h2>
            <span class="card-trend"><i class="fa-solid fa-chart-bar"></i> 單日聆聽習慣</span>
        </div>
    </div>
</div>

<!-- ================= 詳細分析儀表板 ================= -->
<div class="stats-dashboard-grid animate-fade-in" style="display: grid; grid-template-columns: 2fr 1fr; gap: 20px; margin-bottom: 20px;">
    <!-- 近 7 日聽歌趨勢圖 -->
    <div class="dashboard-card glass-panel">
        <div class="card-header">
            <h3><i class="fa-solid fa-chart-line"></i> 近 7 日聽歌趨勢</h3>
            <span class="header-desc">播放次數與聽歌分鐘數雙軸比較</span>
        </div>
        <div class="chart-container" style="height: 300px;">
            <canvas id="timelineChart"></canvas>
        </div>
    </div>

    <!-- 核心歌手佔比圖 -->
    <div class="dashboard-card glass-panel">
        <div class="card-header">
            <h3><i class="fa-solid fa-compact-disc"></i> 核心歌手佔比</h3>
            <span class="header-desc">前五大最愛歌手的分佈比例</span>
        </div>
        <div class="chart-container" style="height: 300px;">
            <canvas id="artistChart"></canvas>
        </div>
    </div>
</div>

<div class="stats-dashboard-grid animate-fade-in" style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 40px;">
    <!-- 24 小時聽歌時段分佈圖 -->
    <div class="dashboard-card glass-panel">
        <div class="card-header">
            <h3><i class="fa-solid fa-clock"></i> 24 小時時段分佈</h3>
            <span class="header-desc">你都在什麼時候聽音樂？</span>
        </div>
        <div class="chart-container" style="height: 300px;">
            <canvas id="hourlyChart"></canvas>
        </div>
    </div>

    <!-- 星期偏好活躍度 -->
    <div class="dashboard-card glass-panel">
        <div class="card-header">
            <h3><i class="fa-solid fa-calendar-days"></i> 星期偏好活躍度</h3>
            <span class="header-desc">你哪一天最常聽音樂？</span>
        </div>
        <div class="chart-container" style="height: 300px;">
            <canvas id="dowChart"></canvas>
        </div>
    </div>
</div>

<script>
    let timelineChart = null;
    let artistChart = null;
    let hourlyChart = null;
    let dowChart = null;

    Chart.defaults.color = 'rgba(255, 255, 255, 0.7)';
    Chart.defaults.font.family = 'Outfit';

    // Load data when page displays
    document.addEventListener('DOMContentLoaded', () => {
        loadStatsData(false);
        setInterval(() => { loadStatsData(false); }, 5000);
    });

    async function loadStatsData(manual = false) {
        const refreshIcon = document.getElementById('refresh-icon');
        if (manual && refreshIcon) refreshIcon.classList.add('fa-spin');

        try {
            // 1. Load Summary
            const summaryResp = await fetch('/api/stats/summary?t=' + Date.now());
            if (summaryResp.ok) {
                const summary = await summaryResp.json();
                document.getElementById('stat-total-songs').textContent = summary.totalSongs;
                document.getElementById('stat-total-plays').textContent = summary.totalPlays;
                document.getElementById('stat-total-artists').textContent = summary.totalArtists;
                document.getElementById('stat-daily-avg-minutes').textContent = `${summary.dailyAvgMinutes} 分`;
                document.getElementById('stat-active-days').textContent = `${summary.activeDays} 天`;
                
                const totalMinutes = Math.round(summary.totalTime / 60);
                if (totalMinutes >= 60) {
                    const hours = Math.floor(totalMinutes / 60);
                    const mins = totalMinutes % 60;
                    document.getElementById('stat-total-time').textContent = `${hours} 小時 ${mins} 分`;
                } else {
                    document.getElementById('stat-total-time').textContent = `${totalMinutes} 分鐘`;
                }
            }

            // 2. Load Advanced Stats
            const advResp = await fetch('/api/stats/advanced?t=' + Date.now());
            if (advResp.ok) {
                const adv = await advResp.json();
                document.getElementById('stat-max-loop').textContent = `${adv.maxLoopCount} 次`;
                
                // Calculate favorite period
                if (adv.hourlyData && adv.hourlyData.length > 0) {
                    let morning=0, afternoon=0, evening=0, night=0;
                    adv.hourlyData.forEach(d => {
                        let h = parseInt(d.hour);
                        if(h>=5 && h<12) morning += d.count;
                        else if(h>=12 && h<18) afternoon += d.count;
                        else if(h>=18 && h<23) evening += d.count;
                        else night += d.count;
                    });
                    const max = Math.max(morning, afternoon, evening, night);
                    let period = "-";
                    if (max === 0) period = "尚無資料";
                    else if (max === morning) period = "晨間型 (05~11)";
                    else if (max === afternoon) period = "下午型 (12~17)";
                    else if (max === evening) period = "傍晚型 (18~22)";
                    else period = "深夜型 (23~04)";
                    document.getElementById('stat-fav-period').textContent = period;
                }
                
                renderHourlyChart(adv.hourlyData);
                renderDowChart(adv.dowData);
            }

            // 3. Load Timeline Chart
            const timelineResp = await fetch('/api/stats/timeline?t=' + Date.now());
            if (timelineResp.ok) {
                const timelineData = await timelineResp.json();
                renderTimelineChart(timelineData);
            }

            // 4. Load Artist Doughnut
            const artistResp = await fetch('/api/stats/top-artists?t=' + Date.now());
            if (artistResp.ok) {
                const topArtists = await artistResp.json();
                renderArtistChart(topArtists);
            }

        } catch (err) {
            console.error('Error loading statistics:', err);
        } finally {
            if (manual && refreshIcon) {
                setTimeout(() => refreshIcon.classList.remove('fa-spin'), 600);
            }
        }
    }

    function renderTimelineChart(data) {
        const labels = data.map(d => d.play_date.split('-').slice(1).join('/'));
        const plays = data.map(d => d.play_count);
        const durations = data.map(d => d.duration_mins);

        const ctx = document.getElementById('timelineChart').getContext('2d');
        if (timelineChart) {
            timelineChart.data.labels = labels;
            timelineChart.data.datasets[0].data = durations;
            timelineChart.data.datasets[1].data = plays;
            timelineChart.update('none');
            return;
        }

        const gradient = ctx.createLinearGradient(0, 0, 0, 300);
        gradient.addColorStop(0, 'rgba(29, 185, 84, 0.4)');
        gradient.addColorStop(1, 'rgba(29, 185, 84, 0.0)');

        timelineChart = new Chart(ctx, {
            type: 'bar',
            data: {
                labels: labels,
                datasets: [
                    {
                        type: 'line',
                        label: '播放時長 (分鐘)',
                        data: durations,
                        borderColor: '#1DB954',
                        borderWidth: 3,
                        backgroundColor: gradient,
                        fill: true,
                        tension: 0.4,
                        yAxisID: 'y1'
                    },
                    {
                        type: 'bar',
                        label: '播放次數',
                        data: plays,
                        backgroundColor: 'rgba(255, 255, 255, 0.25)',
                        borderRadius: 4,
                        yAxisID: 'y'
                    }
                ]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                interaction: { mode: 'index', intersect: false },
                plugins: { legend: { display: true, position: 'top' } },
                scales: {
                    x: { grid: { display: false } },
                    y: { type: 'linear', display: true, position: 'left', grid: { color: 'rgba(255,255,255,0.05)' } },
                    y1: { type: 'linear', display: true, position: 'right', grid: { drawOnChartArea: false } }
                }
            }
        });
    }

    function renderArtistChart(data) {
        const labels = data.map(d => d.artist);
        const counts = data.map(d => d.play_count);

        const ctx = document.getElementById('artistChart').getContext('2d');
        if (artistChart) {
            artistChart.data.labels = labels;
            artistChart.data.datasets[0].data = counts;
            artistChart.update('none');
            return;
        }

        artistChart = new Chart(ctx, {
            type: 'doughnut',
            data: {
                labels: labels,
                datasets: [{
                    data: counts,
                    backgroundColor: ['#1DB954', '#F0F0F0', '#7A7A7A', '#0E7A36', '#B3B3B3'],
                    borderWidth: 0,
                    hoverOffset: 10
                }]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                plugins: {
                    legend: { position: 'right' }
                },
                cutout: '65%'
            }
        });
    }

    function renderHourlyChart(data) {
        let hours = Array(24).fill(0);
        if (data) data.forEach(d => { hours[parseInt(d.hour)] = d.count; });
        
        const labels = Array.from({length:24}, (_, i) => `${i}時`);
        const ctx = document.getElementById('hourlyChart').getContext('2d');
        if (hourlyChart) {
            hourlyChart.data.datasets[0].data = hours;
            hourlyChart.update('none');
            return;
        }

        hourlyChart = new Chart(ctx, {
            type: 'bar',
            data: {
                labels: labels,
                datasets: [{
                    label: '累計播放次數',
                    data: hours,
                    backgroundColor: 'rgba(29, 185, 84, 0.7)',
                    borderRadius: 4
                }]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    x: { grid: { display: false } },
                    y: { grid: { color: 'rgba(255,255,255,0.05)' } }
                }
            }
        });
    }

    function renderDowChart(data) {
        let dow = Array(7).fill(0);
        if (data) data.forEach(d => { dow[parseInt(d.dow)] = d.count; });
        // dow mapping: 0=Sun, 1=Mon...
        // Let's shift to Mon-Sun
        const sortedDow = [dow[1], dow[2], dow[3], dow[4], dow[5], dow[6], dow[0]];
        const labels = ['週一', '週二', '週三', '週四', '週五', '週六', '週日'];

        const ctx = document.getElementById('dowChart').getContext('2d');
        if (dowChart) {
            dowChart.data.datasets[0].data = sortedDow;
            dowChart.update('none');
            return;
        }

        dowChart = new Chart(ctx, {
            type: 'polarArea',
            data: {
                labels: labels,
                datasets: [{
                    data: sortedDow,
                    backgroundColor: [
                        'rgba(29, 185, 84, 0.9)', 'rgba(29, 185, 84, 0.75)', 'rgba(29, 185, 84, 0.6)',
                        'rgba(29, 185, 84, 0.45)', 'rgba(29, 185, 84, 0.3)', 'rgba(255, 255, 255, 0.35)', 'rgba(255, 255, 255, 0.2)'
                    ],
                    borderWidth: 1,
                    borderColor: 'rgba(0,0,0,0.2)'
                }]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                scales: {
                    r: {
                        grid: { color: 'rgba(255,255,255,0.1)' },
                        ticks: { display: false }
                    }
                },
                plugins: { legend: { position: 'right' } }
            }
        });
    }

    function escapeHtml(text) {
        if (!text) return '';
        const map = {
            '&': '&amp;',
            '<': '&lt;',
            '>': '&gt;',
            '"': '&quot;',
            "'": '&#039;'
        };
        return text.replace(/[&<>"']/g, function(m) { return map[m]; });
    }
</script>

<%- include('footer') %>
