<%- include('header') %>

<div class="page-header animate-fade-in">
    <div>
        <h1>統計數據</h1>
    </div>
    
    <button class="refresh-btn" onclick="loadStatsData(true)">
        <i class="fa-solid fa-arrows-rotate" id="refresh-icon"></i> 立即更新
    </button>
</div>

<!-- ================= 數據概覽卡片 ================= -->
<div class="stats-overview-grid animate-fade-in">
    <!-- 卡片 1: 播放次數 -->
    <div class="stats-card glass-panel">
        <div class="card-icon"><i class="fa-solid fa-play"></i></div>
        <div class="card-info">
            <span class="card-label">播放次數</span>
            <h2 class="card-value" id="stat-total-plays">0</h2>
            <span class="card-trend"><i class="fa-solid fa-arrow-trend-up"></i> 播放事件累計</span>
        </div>
    </div>

    <!-- 卡片 2: 不同的曲目 -->
    <div class="stats-card glass-panel">
        <div class="card-icon"><i class="fa-solid fa-music"></i></div>
        <div class="card-info">
            <span class="card-label">不同的曲目</span>
            <h2 class="card-value" id="stat-total-songs">0</h2>
            <span class="card-trend"><i class="fa-solid fa-compact-disc"></i> 獨特歌曲庫</span>
        </div>
    </div>
    
    <!-- 卡片 3: 播放分鐘數 -->
    <div class="stats-card glass-panel">
        <div class="card-icon"><i class="fa-solid fa-clock"></i></div>
        <div class="card-info">
            <span class="card-label">播放分鐘數</span>
            <h2 class="card-value" id="stat-total-time">0 分鐘</h2>
            <span class="card-trend"><i class="fa-solid fa-hourglass-half"></i> 累計聆聽時間</span>
        </div>
    </div>

    <!-- 卡片 4: 不同的藝人 -->
    <div class="stats-card glass-panel">
        <div class="card-icon"><i class="fa-solid fa-user-astronaut"></i></div>
        <div class="card-info">
            <span class="card-label">不同的藝人</span>
            <h2 class="card-value" id="stat-total-artists">0</h2>
            <span class="card-trend"><i class="fa-solid fa-users"></i> 獨特藝人數量</span>
        </div>
    </div>

    <!-- 卡片 5: 不同的專輯 -->
    <div class="stats-card glass-panel">
        <div class="card-icon"><i class="fa-solid fa-record-vinyl"></i></div>
        <div class="card-info">
            <span class="card-label">不同的專輯</span>
            <h2 class="card-value" id="stat-total-albums">0</h2>
            <span class="card-trend"><i class="fa-solid fa-circle-dot"></i> 預估聆聽專輯</span>
        </div>
    </div>

    <!-- 卡片 6: 每日平均播放次數 -->
    <div class="stats-card glass-panel">
        <div class="card-icon"><i class="fa-solid fa-calendar-day"></i></div>
        <div class="card-info">
            <span class="card-label">每日平均播放次數</span>
            <h2 class="card-value" id="stat-daily-avg-plays">0 次</h2>
            <span class="card-trend"><i class="fa-solid fa-chart-bar"></i> 單日播放活躍度</span>
        </div>
    </div>

    <!-- 卡片 7: 每日平均播放分鐘數 -->
    <div class="stats-card glass-panel">
        <div class="card-icon"><i class="fa-solid fa-hourglass-start"></i></div>
        <div class="card-info">
            <span class="card-label">每日平均播放分鐘數</span>
            <h2 class="card-value" id="stat-daily-avg-minutes">0 分</h2>
            <span class="card-trend"><i class="fa-solid fa-chart-line"></i> 單日聆聽時長</span>
        </div>
    </div>
</div>

<!-- ================= 詳細分析儀表板 ================= -->
<div class="stats-dashboard-grid animate-fade-in" style="display: block;">
    <!-- 近 7 日聽歌趨勢圖 -->
    <div class="dashboard-card glass-panel" style="margin-bottom: 40px;">
        <div class="card-header">
            <h3><i class="fa-solid fa-chart-line"></i> 近 7 日聽歌活躍度</h3>
            <span class="header-desc">每日累計播放次數時間線</span>
        </div>
        <div class="chart-container">
            <canvas id="timelineChart"></canvas>
        </div>
    </div>
</div>

<script>
    let timelineChart = null;

    // Load data when page displays
    document.addEventListener('DOMContentLoaded', () => {
        loadStatsData(false);
        
        // Auto refresh every 5 seconds
        setInterval(() => {
            loadStatsData(false);
        }, 5000);
    });

    async function loadStatsData(manual = false) {
        const refreshIcon = document.getElementById('refresh-icon');
        if (manual && refreshIcon) {
            refreshIcon.classList.add('fa-spin');
        }

        try {
            // 1. Load Summary
            const summaryResp = await fetch('/api/stats/summary?t=' + Date.now());
            if (summaryResp.ok) {
                const summary = await summaryResp.json();
                document.getElementById('stat-total-songs').textContent = summary.totalSongs;
                document.getElementById('stat-total-plays').textContent = summary.totalPlays;
                document.getElementById('stat-total-artists').textContent = summary.totalArtists;
                document.getElementById('stat-total-albums').textContent = summary.totalAlbums;
                document.getElementById('stat-daily-avg-plays').textContent = `${summary.dailyAvgPlays} 次`;
                document.getElementById('stat-daily-avg-minutes').textContent = `${summary.dailyAvgMinutes} 分`;
                
                // Format time into hours & minutes
                const totalMinutes = Math.round(summary.totalTime / 60);
                if (totalMinutes >= 60) {
                    const hours = Math.floor(totalMinutes / 60);
                    const mins = totalMinutes % 60;
                    document.getElementById('stat-total-time').textContent = `${hours} 小時 ${mins} 分`;
                } else {
                    document.getElementById('stat-total-time').textContent = `${totalMinutes} 分鐘`;
                }
            }



            // 3. Load Timeline Chart
            const timelineResp = await fetch('/api/stats/timeline?t=' + Date.now());
            if (timelineResp.ok) {
                const timelineData = await timelineResp.json();
                renderTimelineChart(timelineData);
            }

        } catch (err) {
            console.error('Error loading statistics:', err);
        } finally {
            if (manual && refreshIcon) {
                setTimeout(() => {
                    refreshIcon.classList.remove('fa-spin');
                }, 600);
            }
        }
    }

    function renderTimelineChart(data) {
        const labels = data.map(d => {
            // Convert YYYY-MM-DD to MM/DD for cleaner display
            const parts = d.play_date.split('-');
            return parts.length >= 3 ? `${parts[1]}/${parts[2]}` : d.play_date;
        });
        const values = data.map(d => d.play_count);

        const ctx = document.getElementById('timelineChart').getContext('2d');
        
        if (timelineChart) {
            timelineChart.data.labels = labels;
            timelineChart.data.datasets[0].data = values;
            timelineChart.update('none'); // silent update
            return;
        }

        // Custom Gradient
        const gradient = ctx.createLinearGradient(0, 0, 0, 300);
        gradient.addColorStop(0, 'rgba(29, 185, 84, 0.4)');
        gradient.addColorStop(1, 'rgba(29, 185, 84, 0.0)');

        timelineChart = new Chart(ctx, {
            type: 'line',
            data: {
                labels: labels,
                datasets: [{
                    label: '每日播放次數',
                    data: values,
                    borderColor: '#1DB954',
                    borderWidth: 3,
                    backgroundColor: gradient,
                    fill: true,
                    tension: 0.4,
                    pointBackgroundColor: '#1ED760',
                    pointBorderColor: '#ffffff',
                    pointBorderWidth: 2,
                    pointRadius: 5,
                    pointHoverRadius: 7,
                    shadowColor: 'rgba(29, 185, 84, 0.5)',
                    shadowBlur: 10
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        display: false
                    },
                    tooltip: {
                        backgroundColor: 'rgba(15, 23, 42, 0.95)',
                        titleColor: '#ffffff',
                        bodyColor: '#86efac',
                        borderColor: 'rgba(255, 255, 255, 0.1)',
                        borderWidth: 1,
                        padding: 12,
                        cornerRadius: 10,
                        displayColors: false,
                        titleFont: {
                            family: 'Outfit',
                            size: 14,
                            weight: 'bold'
                        },
                        bodyFont: {
                            family: 'Outfit',
                            size: 13
                        }
                    }
                },
                scales: {
                    y: {
                        grid: {
                            color: 'rgba(255, 255, 255, 0.05)'
                        },
                        ticks: {
                            color: 'rgba(255, 255, 255, 0.5)',
                            font: {
                                family: 'Outfit',
                                size: 12
                            },
                            stepSize: 1,
                            precision: 0
                        },
                        border: {
                            dash: [5, 5]
                        }
                    },
                    x: {
                        grid: {
                            display: false
                        },
                        ticks: {
                            color: 'rgba(255, 255, 255, 0.5)',
                            font: {
                                family: 'Outfit',
                                size: 12
                            }
                        }
                    }
                }
            }
        });
    }

    function escapeHtml(text) {
        if (!text) return '';
        const map = {
            '&': '&amp;',
            '<': '&lt;',
            '>': '&gt;',
            '"': '&quot;',
            "'": '&#039;'
        };
        return text.replace(/[&<>"']/g, function(m) { return map[m]; });
    }
</script>

<%- include('footer') %>
